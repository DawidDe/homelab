# General Settings
UI_CONFIG_DISABLED=true
APP_NAME="Pocket ID"
SESSION_DURATION=60
HOME_PAGE_URL="/settings/apps"
ALLOW_OWN_ACCOUNT_EDIT=false
DISABLE_ANIMATIONS=false
ACCENT_COLOR="default"

# User Settings
ALLOW_USER_SIGNUPS="disabled"

# Email Settings
SMTP_HOST="smtp.eu.mailgun.org"
SMTP_PORT=587
SMTP_TLS="starttls"
SMTP_FROM="pocket-id@domain.de"
SMTP_USER="pocket-id@domain.de"
SMTP_PASSWORD=""

EMAIL_LOGIN_NOTIFICATION_ENABLED=true
EMAIL_VERIFICATION_ENABLED=true
EMAIL_ONE_TIME_ACCESS_AS_ADMIN_ENABLED=false
EMAIL_API_KEY_EXPIRATION_ENABLED=true
EMAIL_ONE_TIME_ACCESS_AS_UNAUTHENTICATED_ENABLED=false

# LADP Settings
LDAP_ENABLED=false

# Reverse Proxy Settings
APP_URL="https://pocket-id.domain.de/"
TRUST_PROXY=true

# Encryption Settings
ENCRYPTION_KEY=""